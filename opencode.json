{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-opencode"],
  "provider": {
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:OPENROUTER_API_KEY}",
        "headers": {
          "HTTP-Referer": "https://github.com/elementary-english-lesson-designer",
          "X-Title": "Elementary English Lesson Designer"
        }
      }
    }
  },
  "model": "openrouter/anthropic/claude-3.5-sonnet",
  "small_model": "openrouter/anthropic/claude-3-haiku"
}
